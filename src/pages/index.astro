---
import Layout from '../layouts/Layout.astro';
import MobileMenu from '../components/MobileMenu';
import FaqAccordion from '../components/FaqAccordion';
import ContactForm from '../components/ContactForm';
---

<Layout
  title="Webdesigner Stuttgart | Professionelle Website ab 499 € — Benjamin Reder"
  description="Webdesign aus Stuttgart: Kostenloser Designvorschlag, Festpreise ab 499 €, fertig in 5–7 Tagen. Professionelle Website erstellen lassen von Benjamin Reder."
>
  <!-- Navigation -->
  <header class="sticky top-0 bg-white/95 backdrop-blur-sm border-b border-slate-100 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="#" class="text-xl font-bold text-slate-900">Benjamin Reder</a>

        <nav class="hidden lg:flex items-center gap-6">
          <a href="#versprechen" class="text-sm text-slate-600 hover:text-cta transition-colors">Versprechen</a>
          <a href="#ablauf" class="text-sm text-slate-600 hover:text-cta transition-colors">Ablauf</a>
          <a href="#preise" class="text-sm text-slate-600 hover:text-cta transition-colors">Preise</a>
          <a href="#referenzen" class="text-sm text-slate-600 hover:text-cta transition-colors">Referenzen</a>
          <a href="#ueber-mich" class="text-sm text-slate-600 hover:text-cta transition-colors">Über mich</a>
          <a href="#faq" class="text-sm text-slate-600 hover:text-cta transition-colors">FAQ</a>
        </nav>

        <div class="hidden lg:flex items-center gap-4">
          <a href="tel:+4915258578794" class="flex items-center gap-1.5 text-sm text-slate-600 hover:text-cta transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Anrufen
          </a>
          <a href="#kontakt" class="bg-cta hover:bg-cta-hover text-white text-sm font-semibold py-2 px-4 rounded-lg transition-colors">
            Gratis-Entwurf anfordern
          </a>
        </div>

        <MobileMenu client:load />
      </div>
    </div>
  </header>

  <main>
  <!-- Hero -->
  <section class="bg-navy text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy via-navy to-slate-800 opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-36">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-6">
            Dein Betrieb verdient eine professionelle Website.
          </h1>
          <p class="text-lg md:text-xl text-slate-300 mb-8">
            Kostenloser Designvorschlag. Kein Risiko, keine Verpflichtung.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#kontakt" class="inline-flex items-center justify-center bg-cta hover:bg-cta-hover text-white font-semibold py-3 px-8 rounded-lg text-lg transition-colors">
              Gratis-Entwurf anfordern
            </a>
            <a href="tel:+4915258578794" class="inline-flex items-center justify-center gap-2 text-slate-300 hover:text-white transition-colors py-3 px-4">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Oder ruf mich einfach an
            </a>
          </div>
        </div>
        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <div class="w-64 h-64 md:w-80 md:h-80 rounded-full border-4 border-cta overflow-hidden">
              <img src="/images/Benjamin_Profilbild.webp" alt="Benjamin Reder" class="w-full h-full object-cover object-top" />
            </div>
          </div>
        </div>
      </div>
      <div class="flex justify-center mt-12">
        <a href="#versprechen" class="text-slate-400 hover:text-white transition-colors animate-bounce">
          <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Versprechen -->
  <section id="versprechen" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Mein Versprechen</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="bg-white rounded-2xl p-8 text-center shadow-lg border border-slate-100">
          <div class="flex justify-center mb-5">
            <div class="w-16 h-16 bg-cta/10 rounded-2xl flex items-center justify-center">
              <svg class="h-8 w-8 text-cta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Kostenloser Entwurf</h3>
          <p class="text-slate-600">Du siehst vorher, was du bekommst</p>
        </div>
        <!-- Card 2 -->
        <div class="bg-white rounded-2xl p-8 text-center shadow-lg border border-slate-100">
          <div class="flex justify-center mb-5">
            <div class="w-16 h-16 bg-cta/10 rounded-2xl flex items-center justify-center">
              <svg class="h-8 w-8 text-cta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Festpreis ab 499 €</h3>
          <p class="text-slate-600">Keine versteckten Kosten</p>
        </div>
        <!-- Card 3 -->
        <div class="bg-white rounded-2xl p-8 text-center shadow-lg border border-slate-100">
          <div class="flex justify-center mb-5">
            <div class="w-16 h-16 bg-cta/10 rounded-2xl flex items-center justify-center">
              <svg class="h-8 w-8 text-cta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Fertig in 5–7 Tagen</h3>
          <p class="text-slate-600">Nicht Wochen oder Monate</p>
        </div>
      </div>
      <p class="text-center mt-12 text-slate-500 italic text-lg">
        Erst der Entwurf, dann die Entscheidung. Immer zum Festpreis.
      </p>
    </div>
  </section>

  <!-- Ablauf -->
  <section id="ablauf" class="py-20 md:py-28 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">So läuft's ab</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <!-- Step 1 -->
        <div class="text-center">
          <div class="flex justify-center mb-6">
            <div class="w-16 h-16 bg-cta rounded-full flex items-center justify-center text-white text-2xl font-bold shadow-lg shadow-cta/25">1</div>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Kurzes Gespräch</h3>
          <p class="text-slate-600">30 Min, kostenlos, telefonisch oder per Video-Call</p>
        </div>
        <!-- Step 2 -->
        <div class="text-center">
          <div class="flex justify-center mb-6">
            <div class="w-16 h-16 bg-cta rounded-full flex items-center justify-center text-white text-2xl font-bold shadow-lg shadow-cta/25">2</div>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Gratis-Designvorschlag</h3>
          <p class="text-slate-600">Ich baue dir einen individuellen Entwurf — kostenlos und unverbindlich.</p>
        </div>
        <!-- Step 3 -->
        <div class="text-center">
          <div class="flex justify-center mb-6">
            <div class="w-16 h-16 bg-cta rounded-full flex items-center justify-center text-white text-2xl font-bold shadow-lg shadow-cta/25">3</div>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Umsetzung</h3>
          <p class="text-slate-600">Dein Feedback, meine Anpassungen, Go-Live in 5–7 Tagen</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pakete & Preise -->
  <section id="preise" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Pakete & Preise</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">
          Alle Pakete inkl. Impressum, Datenschutz, mobil-optimiert und Gratis-Entwurf.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 mt-12 max-w-5xl mx-auto">
        <!-- Starter -->
        <div class="border border-slate-200 rounded-2xl p-8 flex flex-col">
          <h3 class="text-xl font-bold text-slate-900">Starter</h3>
          <p class="text-sm text-slate-500 mb-4">One-Pager</p>
          <div class="text-4xl font-bold text-slate-900 mb-6">499 €</div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Eine Seite</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Mobil-optimiert</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Impressum & Datenschutz</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Gratis-Entwurf inklusive</span>
            </li>
          </ul>
          <a href="#kontakt" class="block text-center border-2 border-slate-300 hover:border-cta text-slate-700 hover:text-cta font-semibold py-3 px-6 rounded-lg transition-colors">
            Gratis-Entwurf anfordern
          </a>
        </div>

        <!-- Business (highlighted) -->
        <div class="border-2 border-cta rounded-2xl p-8 flex flex-col relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-cta text-white text-xs font-bold py-1 px-3 rounded-full">Beliebt</span>
          </div>
          <h3 class="text-xl font-bold text-slate-900">Business</h3>
          <p class="text-sm text-slate-500 mb-4">3–5 Seiten</p>
          <div class="text-4xl font-bold text-slate-900 mb-1">ab 999 €</div>
          <p class="text-sm text-slate-400 mb-6">&nbsp;</p>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">3–5 Unterseiten</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Mobil-optimiert</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Impressum & Datenschutz</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Gratis-Entwurf inklusive</span>
            </li>
          </ul>
          <a href="#kontakt" class="block text-center bg-cta hover:bg-cta-hover text-white font-semibold py-3 px-6 rounded-lg transition-colors">
            Gratis-Entwurf anfordern
          </a>
        </div>

        <!-- Premium -->
        <div class="border border-slate-200 rounded-2xl p-8 flex flex-col">
          <h3 class="text-xl font-bold text-slate-900">Premium</h3>
          <p class="text-sm text-slate-500 mb-4">mit Extras</p>
          <div class="text-4xl font-bold text-slate-900 mb-1">ab 1.499 €</div>
          <p class="text-sm text-slate-400 mb-6">&nbsp;</p>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Unbegrenzte Seiten</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Mobil-optimiert</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">SEO-Optimierung</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Blog/News</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-5 w-5 text-cta shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-600">Gratis-Entwurf inklusive</span>
            </li>
          </ul>
          <a href="#kontakt" class="block text-center bg-slate-800 hover:bg-slate-900 text-white font-semibold py-3 px-6 rounded-lg transition-colors">
            Gratis-Entwurf anfordern
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Referenzen -->
  <section id="referenzen" class="py-20 md:py-28 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Referenzen</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- pferdewert.de -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100">
          <div class="aspect-video bg-slate-100">
            <img src="/images/ref-pferdewert.webp" alt="pferdewert.de — Bewertungsplattform für Pferde" class="w-full h-full object-cover object-top" loading="lazy" />
          </div>
          <div class="p-5">
            <h3 class="font-bold text-slate-900 mb-1">pferdewert.de</h3>
            <p class="text-sm text-slate-600 mb-3">Bewertungsplattform für Pferde</p>
            <a href="https://pferdewert.de" target="_blank" rel="noopener noreferrer" class="text-sm text-cta hover:text-cta-hover font-medium inline-flex items-center gap-1">
              Website besuchen
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
        <!-- pferde-fotoshooting.de -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100">
          <div class="aspect-video bg-slate-100">
            <img src="/images/ref-pferde-fotoshooting.webp" alt="pferde-fotoshooting.de — Online-Fotoshooting für Pferdebesitzer" class="w-full h-full object-cover object-top" loading="lazy" />
          </div>
          <div class="p-5">
            <h3 class="font-bold text-slate-900 mb-1">pferde-fotoshooting.de</h3>
            <p class="text-sm text-slate-600 mb-3">Online-Fotoshooting für Pferde</p>
            <a href="https://pferde-fotoshooting.de" target="_blank" rel="noopener noreferrer" class="text-sm text-cta hover:text-cta-hover font-medium inline-flex items-center gap-1">
              Website besuchen
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
        <!-- svb-brueckers.de -->
